# ============================================================
# laximotech.ai — Next.js Frontend Environment Variables
# Copy to .env.local and fill in real values
# ============================================================

# ── App ──────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── NestJS API ───────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:4000

# ── Auth.js ──────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET=change-this-to-random-32-char-string
AUTH_URL=http://localhost:3000

# Google OAuth — https://console.cloud.google.com
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Magic link email — https://resend.com (optional for dev)
RESEND_API_KEY=

# ── Database (same as API — needed for Auth.js Prisma adapter) ──
DATABASE_URL=postgresql://laximotech:laximotech123@localhost:5433/laximotech

# ── Razorpay (optional for dev) ──────────────────────────────
NEXT_PUBLIC_RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# ── AWS CloudFront CDN ────────────────────────────────────────
NEXT_PUBLIC_CDN_URL=https://cdn.laximotech.ai

# ── OpenAI (Phase 3 — keep server-side only) ─────────────────
OPENAI_API_KEY=
