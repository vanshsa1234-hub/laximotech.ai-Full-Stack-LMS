# ============================================================
# laximotech.ai — NestJS API Environment Variables
# Copy to .env and fill in real values
# ============================================================

# ── App ──────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000
FRONTEND_URL=http://localhost:3000

# ── Database (Docker PostgreSQL) ─────────────────────────────
# After running: docker compose up -d
# Use port 5433 (mapped from container's 5432)
DATABASE_URL=postgresql://laximotech:laximotech123@localhost:5433/laximotech

# ── JWT / Auth ─────────────────────────────────────────────
# Keep this in sync with apps/web/.env.local
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
AUTH_SECRET=laximotech-auth-secret-change-in-production-abcdef1234567890abcd
JWT_SECRET=laximotech-auth-secret-change-in-production-abcdef1234567890abcd
JWT_EXPIRES_IN=7d

# ── AWS S3 (optional for dev — S3 features disabled if missing) ──
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=laximotech-media
CLOUDFRONT_URL=https://cdn.laximotech.ai

# ── Razorpay (optional for dev — payment disabled if missing) ────
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# ── OpenAI (Phase 3) ─────────────────────────────────────────
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ── Email / Resend (optional for dev) ────────────────────────
RESEND_API_KEY=
EMAIL_FROM=noreply@laximotech.ai

# ── Judge0 / Code Playground (Phase 3) ───────────────────────
JUDGE0_API_URL=https://judge0-ce.p.rapidapi.com
JUDGE0_API_KEY=
